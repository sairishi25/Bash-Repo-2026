#!/usr/bin/env bash

# This script fetches the current price of a cryptocurrency against USDT (Tether).
# Usage: crypto-price [COIN]
# Example: crypto-price BTC
# Example: crypto-price ETH

COIN="${1:-BTC}"
# Ensure coin string is completely UPPERCASE using bash built-ins param expansion:
SYMBOL="${COIN^^}USDT"
API_URL="https://api.binance.com/api/v3/ticker/price?symbol=${SYMBOL}"

echo "Fetching price for $COIN..."

