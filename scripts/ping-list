#!/usr/bin/env bash

# This script reads a text file containing domain names and checks if they are online.
# Usage: ping-list domains.txt

FILE=$1

if [[ ! -f "$FILE" ]]; then
    echo "Error: Please provide a valid text file containing domains."
    echo "Usage: ping-list <file_with_domains>"
    exit 1
fi

echo "Pinging domains in $FILE..."
echo "---"

